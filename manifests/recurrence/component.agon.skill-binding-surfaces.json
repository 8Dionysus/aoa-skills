      ],
      "notes": "Skill trigger drift must stay bounded by owner review.",
      "observation_inputs": [
        "agon-skill-binding-candidates"
      ],
      "recommended_actions": [
        "refresh skill binding candidates",
        "do not infer arena authority from workflow shape"
      ],
      "status_ladder": [
        "hint",
        "watch",
        "candidate",
        "review_ready"
      ],
      "suppress_when": [
        "live_protocol_claim_present",
        "hidden_authority_detected"
      ],
      "target_repo": "aoa-skills",
      "thresholds": {
        "candidate_observations": 2,
        "min_unique_evidence_refs": 2,
        "min_unique_sources": 2,
        "review_ready_observations": 3,
        "watch_observations": 1
      }
    }
  ],
  "candidate_targets": [
