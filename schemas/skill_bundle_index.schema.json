{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-skills bundle index",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundle_index_version", "skills", "source_of_truth"],
  "properties": {
    "bundle_index_version": { "type": "integer", "minimum": 2 },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skill_markdown",
        "technique_manifest",
        "runtime_examples",
        "review_checks",
        "status_promotion_reviews",
        "canonical_candidate_reviews"
      ],
      "properties": {
        "skill_markdown": { "type": "string", "minLength": 1 },
        "technique_manifest": { "type": "string", "minLength": 1 },
        "runtime_examples": { "type": "string", "minLength": 1 },
        "review_checks": { "type": "string", "minLength": 1 },
        "status_promotion_reviews": { "type": "string", "minLength": 1 },
        "canonical_candidate_reviews": { "type": "string", "minLength": 1 }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "scope",
          "status",
          "invocation_mode",
          "skill_path",
          "skill_revision",
          "content_hash",
          "technique_dependencies",
          "lineage_state",
          "canonical_candidate_ready",
          "canonical_eval_ready",
          "promotion_review_path",
          "candidate_review_path",
          "support_artifacts",
          "bundle_files",
          "install_profiles",
          "artifact_group_coverage",
          "technique_lineage",
          "generated_surface_versions"
        ],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "scope": { "type": "string", "enum": ["core", "project", "risk"] },
          "status": {
            "type": "string",
            "enum": ["scaffold", "linked", "reviewed", "evaluated", "canonical", "deprecated"]
          },
          "invocation_mode": {
            "type": "string",
            "enum": ["implicit-friendly", "explicit-preferred", "explicit-only"]
          },
          "skill_path": { "type": "string", "minLength": 1 },
          "skill_revision": { "type": "string", "minLength": 1 },
          "content_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "technique_dependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "lineage_state": { "type": "string", "enum": ["published", "pending"] },
          "canonical_candidate_ready": { "type": "boolean" },
          "canonical_eval_ready": { "type": "boolean" },
          "promotion_review_path": { "type": ["string", "null"] },
          "candidate_review_path": { "type": ["string", "null"] },
          "support_artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "path", "selected_for_runtime_inspection"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "runtime_example",
                    "review_checklist",
                    "promotion_review",
                    "candidate_review"
                  ]
                },
                "path": { "type": "string", "minLength": 1 },
                "selected_for_runtime_inspection": { "type": "boolean" }
              }
            }
          },
          "bundle_files": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "install_profiles": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "artifact_group_coverage": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "technique_lineage": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "repo", "path", "source_ref", "lineage_state"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "repo": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "minLength": 1 },
                "source_ref": { "type": "string", "minLength": 1 },
                "lineage_state": { "type": "string", "enum": ["published", "pending"] }
              }
            }
          },
          "generated_surface_versions": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "catalog",
              "capsule",
              "sections",
              "walkthrough",
              "public_surface",
              "evaluation_matrix",
              "lineage_surface",
              "boundary_matrix",
              "governance_backlog",
              "skill_composition_audit",
              "overlay_readiness",
              "bundle_index",
              "skill_graph"
            ],
            "properties": {
              "catalog": { "type": "integer", "minimum": 1 },
              "capsule": { "type": "integer", "minimum": 1 },
              "sections": { "type": "integer", "minimum": 1 },
              "walkthrough": { "type": "integer", "minimum": 1 },
              "public_surface": { "type": "integer", "minimum": 1 },
              "evaluation_matrix": { "type": "integer", "minimum": 1 },
              "lineage_surface": { "type": "integer", "minimum": 1 },
              "boundary_matrix": { "type": "integer", "minimum": 1 },
              "governance_backlog": { "type": "integer", "minimum": 1 },
              "skill_composition_audit": { "type": "integer", "minimum": 1 },
              "overlay_readiness": { "type": "integer", "minimum": 1 },
              "bundle_index": { "type": "integer", "minimum": 1 },
              "skill_graph": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
