{
  "title": "aoa-skills project foundation profile surface",
  "type": "object",
  "required": [
    "schema_version",
    "source_config",
    "foundation_id",
    "owner_repo",
    "description",
    "canonical_install_profile",
    "kernel_id",
    "outer_ring_id",
    "risk_ring_id",
    "skill_count",
    "skills",
    "kernel_skills",
    "outer_ring_skills",
    "risk_ring_skills"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "source_config": {
      "type": "string",
      "const": "config/skill_pack_profiles.json"
    },
    "foundation_id": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "canonical_install_profile": {
      "type": "string",
      "minLength": 1
    },
    "kernel_id": {
      "type": "string",
      "minLength": 1
    },
    "outer_ring_id": {
      "type": "string",
      "minLength": 1
    },
    "risk_ring_id": {
      "type": "string",
      "minLength": 1
    },
    "skill_count": {
      "type": "integer",
      "minimum": 1
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "kernel_skills": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outer_ring_skills": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_ring_skills": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
