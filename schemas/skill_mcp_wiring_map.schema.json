{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-skills skill MCP wiring map",
  "type": "object",
  "required": [
    "schema_version",
    "mcp_registry",
    "skill_wirings"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "mcp_registry": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "description",
          "transport"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "transport": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "skill_wirings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slug",
          "display_name",
          "short_description",
          "default_prompt",
          "allow_implicit_invocation",
          "mcp_dependencies"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "display_name": {
            "type": "string"
          },
          "short_description": {
            "type": "string"
          },
          "default_prompt": {
            "type": "string"
          },
          "allow_implicit_invocation": {
            "type": "boolean"
          },
          "mcp_dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "preferred_subagents": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "supporting_subagents": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
