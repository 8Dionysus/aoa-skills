{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-skills governance backlog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "governance_backlog_version",
    "source_of_truth",
    "cohorts",
    "review_truth_sync",
    "skills"
  ],
  "properties": {
    "governance_backlog_version": { "type": "integer", "minimum": 1 },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skill_markdown",
        "technique_manifest",
        "status_promotion_reviews",
        "canonical_candidate_reviews",
        "evaluation_fixtures",
        "governance_lanes",
        "evaluation_matrix",
        "public_surface",
        "review_truth_sync"
      ],
      "properties": {
        "skill_markdown": { "type": "string", "minLength": 1 },
        "technique_manifest": { "type": "string", "minLength": 1 },
        "status_promotion_reviews": { "type": "string", "minLength": 1 },
        "canonical_candidate_reviews": { "type": "string", "minLength": 1 },
        "evaluation_fixtures": { "type": "string", "minLength": 1 },
        "governance_lanes": { "type": "string", "minLength": 1 },
        "evaluation_matrix": { "type": "string", "minLength": 1 },
        "public_surface": { "type": "string", "minLength": 1 },
        "review_truth_sync": { "type": "string", "minLength": 1 }
      }
    },
    "cohorts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_ready_without_review",
        "blocked_by_pending_lineage",
        "canonical_maintenance",
        "comparative_pending",
        "review_truth_sync",
        "docs_truth_sync"
      ],
      "properties": {
        "candidate_ready_without_review": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "blocked_by_pending_lineage": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "canonical_maintenance": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "comparative_pending": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "review_truth_sync": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "docs_truth_sync": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "review_truth_sync": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "lineage_state",
          "governance_decision",
          "review_path",
          "reviewed_revision",
          "current_revision",
          "runtime_skill_md_meaning_changed",
          "issues",
          "truth_synced"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": {
            "type": ["string", "null"],
            "enum": ["scaffold", "linked", "reviewed", "evaluated", "canonical", "deprecated", null]
          },
          "lineage_state": {
            "type": ["string", "null"],
            "enum": ["published", "pending", null]
          },
          "governance_decision": {
            "type": ["string", "null"],
            "enum": ["default_reference", "stay_evaluated", null]
          },
          "review_path": { "type": ["string", "null"] },
          "reviewed_revision": { "type": ["string", "null"] },
          "current_revision": { "type": ["string", "null"] },
          "runtime_skill_md_meaning_changed": {
            "type": ["boolean", "null"]
          },
          "issues": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "truth_synced": { "type": "boolean" }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "scope",
          "skill_path",
          "lineage_state",
          "canonical_candidate_ready",
          "canonical_candidate_blockers",
          "canonical_eval_ready",
          "canonical_eval_blockers",
          "promotion_review_path",
          "candidate_review_path",
          "governance_decision",
          "governance_lane_ids",
          "governance_evidence_case_ids",
          "readiness_reconciliation"
        ],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "status": {
            "type": "string",
            "enum": ["scaffold", "linked", "reviewed", "evaluated", "canonical", "deprecated"]
          },
          "scope": { "type": "string", "enum": ["core", "project", "risk"] },
          "skill_path": { "type": "string", "minLength": 1 },
          "lineage_state": { "type": "string", "enum": ["published", "pending"] },
          "canonical_candidate_ready": { "type": "boolean" },
          "canonical_candidate_blockers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "canonical_eval_ready": { "type": "boolean" },
          "canonical_eval_blockers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "promotion_review_path": { "type": ["string", "null"] },
          "candidate_review_path": { "type": ["string", "null"] },
          "governance_decision": {
            "type": ["string", "null"],
            "enum": ["default_reference", "stay_evaluated", null]
          },
          "governance_lane_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "governance_evidence_case_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "readiness_reconciliation": {
            "type": "string",
            "enum": [
              "governance_and_eval_ready",
              "governance_ready_but_eval_blocked",
              "eval_ready_but_governance_blocked",
              "blocked_in_both",
              "project_overlay_eval_ready",
              "project_overlay_needs_evidence"
            ]
          }
        }
      }
    }
  }
}
