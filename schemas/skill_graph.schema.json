{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-skills skill graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["skill_graph_version", "source_of_truth", "skills", "nodes", "edges"],
  "properties": {
    "skill_graph_version": { "type": "integer", "minimum": 2 },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skill_markdown",
        "technique_manifest",
        "runtime_examples",
        "review_checks",
        "status_promotion_reviews",
        "canonical_candidate_reviews"
      ],
      "properties": {
        "skill_markdown": { "type": "string", "minLength": 1 },
        "technique_manifest": { "type": "string", "minLength": 1 },
        "runtime_examples": { "type": "string", "minLength": 1 },
        "review_checks": { "type": "string", "minLength": 1 },
        "status_promotion_reviews": { "type": "string", "minLength": 1 },
        "canonical_candidate_reviews": { "type": "string", "minLength": 1 }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "scope",
          "status",
          "invocation_mode",
          "skill_path",
          "skill_revision",
          "content_hash",
          "technique_dependencies",
          "lineage_state",
          "canonical_candidate_ready",
          "canonical_eval_ready",
          "promotion_review_path",
          "candidate_review_path",
          "support_artifacts",
          "bundle_files",
          "install_profiles",
          "artifact_group_coverage",
          "technique_lineage",
          "generated_surface_versions"
        ],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "scope": { "type": "string", "enum": ["core", "project", "risk"] },
          "status": {
            "type": "string",
            "enum": ["scaffold", "linked", "reviewed", "evaluated", "canonical", "deprecated"]
          },
          "invocation_mode": {
            "type": "string",
            "enum": ["implicit-friendly", "explicit-preferred", "explicit-only"]
          },
          "skill_path": { "type": "string", "minLength": 1 },
          "skill_revision": { "type": "string", "minLength": 1 },
          "content_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "technique_dependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "lineage_state": { "type": "string", "enum": ["published", "pending"] },
          "canonical_candidate_ready": { "type": "boolean" },
          "canonical_eval_ready": { "type": "boolean" },
          "promotion_review_path": { "type": ["string", "null"] },
          "candidate_review_path": { "type": ["string", "null"] },
          "support_artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "path", "selected_for_runtime_inspection"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "runtime_example",
                    "review_checklist",
                    "promotion_review",
                    "candidate_review"
                  ]
                },
                "path": { "type": "string", "minLength": 1 },
                "selected_for_runtime_inspection": { "type": "boolean" }
              }
            }
          },
          "bundle_files": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "install_profiles": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "artifact_group_coverage": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "technique_lineage": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "repo", "path", "source_ref", "lineage_state"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "repo": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "minLength": 1 },
                "source_ref": { "type": "string", "minLength": 1 },
                "lineage_state": { "type": "string", "enum": ["published", "pending"] }
              }
            }
          },
          "generated_surface_versions": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["skill", "status", "scope", "lineage", "policy", "technique", "profile", "artifact_group"]
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "source", "target"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["maturity", "scope", "lineage", "invocation_policy", "depends_on", "included_in_profile", "available_in_artifact_group"]
          },
          "source": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
