{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-skills release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "included_waves",
    "skill_root",
    "skill_count",
    "explicit_only_count",
    "profile_count",
    "authoring_inputs",
    "generated_files",
    "artifact_groups",
    "authoring_input_digests",
    "generated_file_digests",
    "skill_bundle_revisions",
    "install_profile_revisions",
    "release_identity"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 2 },
    "profile": { "type": "string", "minLength": 1 },
    "included_waves": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 }
    },
    "skill_root": { "type": "string", "minLength": 1 },
    "skill_count": { "type": "integer", "minimum": 0 },
    "explicit_only_count": { "type": "integer", "minimum": 0 },
    "profile_count": { "type": "integer", "minimum": 0 },
    "authoring_inputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "generated_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "artifact_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "profile", "wave", "files"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "profile": { "type": "string", "minLength": 1 },
          "wave": { "type": "integer", "minimum": 1 },
          "files": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "authoring_input_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "generated_file_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "skill_bundle_revisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "skill_revision", "content_hash"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "skill_revision": { "type": "string", "pattern": "^[0-9a-f]{12}$" },
          "content_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "install_profile_revisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "skill_count", "skill_names", "profile_revision"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "skill_count": { "type": "integer", "minimum": 0 },
          "skill_names": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
          },
          "profile_revision": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "release_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changelog",
        "releasing_doc",
        "latest_tagged_version",
        "latest_tagged_date",
        "has_unreleased_changes"
      ],
      "properties": {
        "changelog": { "type": "string", "const": "CHANGELOG.md" },
        "releasing_doc": { "type": "string", "const": "docs/RELEASING.md" },
        "latest_tagged_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "latest_tagged_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "has_unreleased_changes": { "type": "boolean" }
      }
    }
  }
}
