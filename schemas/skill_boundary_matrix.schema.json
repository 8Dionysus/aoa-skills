{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-skills boundary adjacency matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["boundary_matrix_version", "source_of_truth", "skills", "cases"],
  "properties": {
    "boundary_matrix_version": { "type": "integer", "minimum": 1 },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skill_markdown", "technique_manifest", "evaluation_fixtures", "evaluation_snapshots", "governance_lanes"],
      "properties": {
        "skill_markdown": { "type": "string", "minLength": 1 },
        "technique_manifest": { "type": "string", "minLength": 1 },
        "evaluation_fixtures": { "type": "string", "minLength": 1 },
        "evaluation_snapshots": { "type": "string", "minLength": 1 },
        "governance_lanes": { "type": "string", "minLength": 1 }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "scope",
          "skill_path",
          "required_adjacency_coverage",
          "adjacency_use_count",
          "adjacency_do_not_use_count",
          "adjacent_skill_names",
          "governance_lane_ids",
          "adjacency_ready",
          "adjacency_blockers"
        ],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "status": {
            "type": "string",
            "enum": ["scaffold", "linked", "reviewed", "evaluated", "canonical", "deprecated"]
          },
          "scope": { "type": "string", "enum": ["core", "project", "risk"] },
          "skill_path": { "type": "string", "minLength": 1 },
          "required_adjacency_coverage": { "type": "boolean" },
          "adjacency_use_count": { "type": "integer", "minimum": 0 },
          "adjacency_do_not_use_count": { "type": "integer", "minimum": 0 },
          "adjacent_skill_names": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "governance_lane_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "adjacency_ready": { "type": "boolean" },
          "adjacency_blockers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "adjacent_skill", "case_id", "expected", "prompt", "snapshot_path", "governance_lane_ids", "blockers"],
        "properties": {
          "skill": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "adjacent_skill": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "case_id": { "type": "string", "minLength": 1 },
          "expected": { "type": "string", "enum": ["use", "do_not_use"] },
          "prompt": { "type": "string", "minLength": 1 },
          "snapshot_path": { "type": "string", "minLength": 1 },
          "governance_lane_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "blockers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
