{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-skills skill frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "scope",
    "status",
    "summary",
    "invocation_mode",
    "technique_dependencies"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9-]+$"
    },
    "scope": {
      "type": "string",
      "enum": [
        "core",
        "project",
        "risk"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "scaffold",
        "linked",
        "reviewed",
        "evaluated",
        "canonical",
        "deprecated"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "invocation_mode": {
      "type": "string",
      "enum": [
        "implicit-friendly",
        "explicit-preferred",
        "explicit-only"
      ]
    },
    "technique_dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^AOA-T-[A-Z0-9-]+$"
      }
    }
  }
}
