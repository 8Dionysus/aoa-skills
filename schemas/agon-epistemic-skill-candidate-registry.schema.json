{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "count": {
      "const": 9
    },
    "digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "registry_id": {
      "const": "agon.epistemic_skill_candidates.registry.v1"
    },
    "runtime_posture": {
      "const": "candidate_only"
    },
    "skills": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "bounded_workflow_for": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "candidate_outputs": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "forbidden_effects": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 10,
            "type": "array",
            "uniqueItems": true
          },
          "live_protocol": {
            "const": false
          },
          "owner_repo": {
            "const": "aoa-skills"
          },
          "runtime_effect": {
            "enum": [
              "none",
              "candidate_only",
              "local_dry_run_candidate_only",
              "local_rehearsal_candidate_only"
            ]
          },
          "skill_id": {
            "minLength": 1,
            "type": "string"
          },
          "status": {
            "const": "requested_only_candidate"
          },
          "trigger_boundary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "bounded_workflow_for",
          "candidate_outputs",
          "forbidden_effects",
          "live_protocol",
          "owner_repo",
          "runtime_effect",
          "skill_id",
          "status",
          "trigger_boundary"
        ],
        "type": "object"
      },
      "maxItems": 9,
      "minItems": 9,
      "type": "array"
    },
    "wave": {
      "const": "XV"
    }
  },
  "required": [
    "registry_id",
    "wave",
    "runtime_posture",
    "count",
    "skills",
    "digest"
  ],
  "title": "aoa-skills Agon Epistemic Skill Candidate Registry",
  "type": "object"
}
