{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-skills route followthrough decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_kind",
    "candidate_ref",
    "verdict",
    "owner_repo",
    "owner_shape",
    "nearest_wrong_target",
    "why_now",
    "why_not_nearest_wrong_target",
    "next_artifact_kind",
    "approval_posture",
    "stop_conditions",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "route_followthrough_decision_v1"
    },
    "decision_kind": {
      "const": "route_followthrough_decision"
    },
    "cluster_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "candidate_ref": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": [
        "land_direct",
        "stage_seed",
        "reanchor_owner",
        "prove_first",
        "merge_into_existing",
        "defer",
        "drop"
      ]
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1
    },
    "owner_shape": {
      "type": "string",
      "minLength": 1
    },
    "nearest_wrong_target": {
      "type": "string",
      "minLength": 1
    },
    "why_now": {
      "type": "string",
      "minLength": 1
    },
    "why_not_nearest_wrong_target": {
      "type": "string",
      "minLength": 1
    },
    "next_artifact_kind": {
      "type": "string",
      "minLength": 1
    },
    "approval_posture": {
      "type": "string",
      "minLength": 1
    },
    "seed_required": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "proof_bundle_hint": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "writeback_hint": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "stats_refresh_hint": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
